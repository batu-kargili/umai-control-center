# Copy this file to .env beside docker-compose.yaml and adjust values for your VM.

COMPOSE_PROJECT_NAME=umai-all-in-one-vm

# Published image references for the three UMAI components.
UMAI_ENGINE_IMAGE=umai/umai-enterprise-engine:latest
UMAI_SERVICE_IMAGE=umai/umai-enterprise-service:latest
UMAI_CONTROLCENTER_IMAGE=umai/umai-enterprise-control-center:latest

# Host-file names the testers will use after editing /etc/hosts or the Windows hosts file.
CONTROL_CENTER_HOST=umai-console.test
API_HOST=umai-api.test

# Exposed host ports.
CONTROL_CENTER_PORT=3000
SERVICE_PORT=8080
ENGINE_PORT=8081
ORACLE_PORT=1521
REDIS_PORT=6379
LDAP_PORT=1389
PHPLDAPADMIN_PORT=8088

# Optional license mount. Keep strict mode false if you are not mounting a signed license file yet.
UMAI_LICENSE_DIR=./license
UMAI_LICENSE_KEY=
DUVARAI_LICENSE_PUBLIC_KEY=
DUVARAI_LICENSE_STRICT=false

# Oracle bootstrap note:
# The bundled init SQL creates umai_app / ChangeMe123 inside FREEPDB1.
# If you change DUVARAI_DATABASE_URL away from that user or service, update bootstrap/oracle/01-umai-bootstrap.sql too.
ORACLE_SYS_PASSWORD=OracleSys123
ORACLE_CHARACTERSET=AL32UTF8
DUVARAI_DATABASE_ENGINE=oracle
DUVARAI_DATABASE_URL=oracle+oracledb_async://umai_app:ChangeMe123@oracle-free:1521/?service_name=FREEPDB1
DUVARAI_DATABASE_POOL_SIZE=5
DUVARAI_DATABASE_MAX_OVERFLOW=10
DUVARAI_DATABASE_CONNECT_TIMEOUT_SECONDS=

# Redis shared by the service and engine.
UMAI_ENGINE_REDIS_URL=redis://redis:6379/0
DUVARAI_REDIS_URL=redis://redis:6379/0

# Browser origin for the control center in hosts-file / HTTP mode.
DUVARAI_CORS_ALLOW_ORIGINS=["http://umai-console.test:3000"]

# Guardrail runtime profile used by the service and executed by the engine.
DUVARAI_DEFAULT_GUARDRAIL_LLM_PROVIDER=CUSTOMER_ONPREM
DUVARAI_DEFAULT_GUARDRAIL_LLM_BASE_URL=https://llm.customer.local/openai/v1
DUVARAI_DEFAULT_GUARDRAIL_LLM_MODEL=gpt-4o-mini
DUVARAI_DEFAULT_GUARDRAIL_LLM_TIMEOUT_MS=2000
DUVARAI_DEFAULT_GUARDRAIL_LLM_AUTH_TYPE=header
DUVARAI_DEFAULT_GUARDRAIL_LLM_AUTH_SECRET_ENV=LLM_API_KEY
DUVARAI_DEFAULT_GUARDRAIL_LLM_AUTH_HEADER_NAME=api-key

# Provide the actual secret env that matches DUVARAI_DEFAULT_GUARDRAIL_LLM_AUTH_SECRET_ENV.
LLM_API_KEY=change-me
OPENAI_API_KEY=
AZURE_OPENAI_API_KEY=
GROQ_API_KEY=
HF_TOKEN=

SERVICE_LOG_LEVEL=INFO
ENGINE_LOG_LEVEL=INFO

DUVARAI_STORE_REQUEST_PAYLOADS=false
DUVARAI_AUDIT_REDACTION_ENABLED=true
DUVARAI_AUDIT_REDACTION_PATTERNS_JSON=
DUVARAI_SIEM_ENDPOINTS_JSON=
UMAI_SNAPSHOT_SIGNING_KEY=local-snapshot-signing-key-change-me
UMAI_SNAPSHOT_SIGNING_KEY_ID=default

# Keep false unless control-center to service admin auth is implemented.
DUVARAI_ENFORCE_ADMIN_JWT=false
DUVARAI_ADMIN_JWT_HS256_SECRET=

DUVARAI_OPENAI_API_KEY=
DUVARAI_OPENAI_MODEL=gpt-4o-mini
DUVARAI_OPENAI_BASE_URL=https://api.openai.com/v1
DUVARAI_OPENAI_TIMEOUT_SECONDS=25

DUVARAI_EXTENSION_INGEST_BEARER_TOKEN=
DUVARAI_EXTENSION_POLICY_JSON=
DUVARAI_EXTENSION_BOOTSTRAP_PUBLIC_KEY_PEM=
EXTENSION_CONNECT_JWT_SECRET=local-extension-secret-change-me
NEXT_PUBLIC_UMAI_EXTENSION_ID=cpcepfngmlphbdmfpnkhlbhhiijeppcn

CONTROL_CENTER_SESSION_SECRET=local-control-center-session-secret-change-me
CONTROL_CENTER_SESSION_TTL_SECONDS=43200
CONTROL_CENTER_SESSION_SECURE=false

# OpenLDAP instance hosted on the same VM.
# If you change LDAP_DOMAIN or LDAP_BASE_DN, also update bootstrap/ldap/01-users.ldif.
LDAP_ORGANISATION=UMAI Local
LDAP_DOMAIN=umai.local
LDAP_BASE_DN=dc=umai,dc=local
LDAP_ADMIN_PASSWORD=admin123
LDAP_CONFIG_PASSWORD=config123
LDAP_URL=ldap://openldap:389
LDAP_BIND_DN=cn=admin,dc=umai,dc=local
LDAP_BIND_PASSWORD=admin123
LDAP_USER_SEARCH_BASE=ou=users,dc=umai,dc=local
LDAP_USER_SEARCH_FILTER=
LDAP_USERNAME_ATTRIBUTE=uid
LDAP_DISPLAY_NAME_ATTRIBUTE=cn
LDAP_EMAIL_ATTRIBUTE=mail
LDAP_GROUP_ATTRIBUTE=memberOf
LDAP_ALLOWED_GROUPS=
LDAP_TIMEOUT_MS=10000
LDAP_CONNECT_TIMEOUT_MS=10000
LDAP_INSECURE_SKIP_VERIFY=false
PHPLDAPADMIN_HTTPS=false

# These seeded values must stay aligned so control-center users land in the tenant created in Oracle.
CONTROL_CENTER_ORGANIZATION_ID=72c1e7a6-cd8b-4e69-b0a4-1549582a98f8
CONTROL_CENTER_ORGANIZATION_NAME=XYZ Sigorta PoC
CONTROL_CENTER_ORGANIZATION_PLAN=enterprise
CONTROL_CENTER_ORGANIZATION_LICENSE_EXPIRES_AT=2030-01-01T00:00:00Z
CONTROL_CENTER_DEFAULT_ENVIRONMENT_ID=
CONTROL_CENTER_DEFAULT_PROJECT_ID=

DUVARAI_SEED_TENANT_ID=72c1e7a6-cd8b-4e69-b0a4-1549582a98f8
DUVARAI_SEED_TENANT_NAME=XYZ Sigorta PoC
DUVARAI_SEED_LICENSE_DAYS=3650
DUVARAI_SEED_LICENSE_PLAN=enterprise
DUVARAI_SEED_ALLOW_LLM_CALLS=true
